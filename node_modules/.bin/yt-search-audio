#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")
basedir_win="$basedir"
exe=""
msys=""

case `uname -a` in
  *CYGWIN*|*MINGW*|*MSYS*)
    if command -v cygpath > /dev/null 2>&1; then
      basedir_win=`cygpath -w "$basedir"`
    fi
    exe=".exe"
    msys="true"
  ;;
  *WSL2*)
    if command -v wslpath > /dev/null 2>&1; then
      basedir_win="$(wslpath -w "$basedir" 2> /dev/null)"
      if [ $? -ne 0 ] || [ -z "$basedir_win" ]; then
        basedir_win="$basedir"
      else
        exe=".exe"
      fi
    fi
  ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/ubuntu/project_extracted/node_modules/.pnpm/yt-search@2.13.1/node_modules/yt-search/node_modules:/home/ubuntu/project_extracted/node_modules/.pnpm/yt-search@2.13.1/node_modules:/home/ubuntu/project_extracted/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/ubuntu/project_extracted/node_modules/.pnpm/yt-search@2.13.1/node_modules/yt-search/node_modules:/home/ubuntu/project_extracted/node_modules/.pnpm/yt-search@2.13.1/node_modules:/home/ubuntu/project_extracted/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -n "$exe" ] && [ -x "$basedir//bin/bash.exe" ]; then
  exec "$basedir//bin/bash.exe"  "$basedir_win/../yt-search/bin/mpv_audio.sh" "$@"
elif [ -x "$basedir//bin/bash" ]; then
  exec "$basedir//bin/bash"  "$basedir/../yt-search/bin/mpv_audio.sh" "$@"
elif command -v /bin/bash >/dev/null 2>&1; then
  exec /bin/bash  "$basedir/../yt-search/bin/mpv_audio.sh" "$@"
elif [ -n "$exe" ] && command -v /bin/bash.exe >/dev/null 2>&1; then
  exec /bin/bash.exe  "$basedir_win/../yt-search/bin/mpv_audio.sh" "$@"
else
  exec /bin/bash  "$basedir/../yt-search/bin/mpv_audio.sh" "$@"
fi
